# =============================================================================
# .env.staging — Template à copier sur le serveur dans /root/aquacare/.env.staging
# NE PAS COMMITTER avec les vraies valeurs (ce fichier est un exemple)
#
# Générer de nouvelles clés :
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# =============================================================================

DJANGO_SETTINGS_MODULE=aquacare_api.settings.staging
DJANGO_ENVIRONMENT=staging
DJANGO_SECRET_KEY=<NOUVELLE_CLE_DIFFERENTE_DE_PROD>
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=77.237.241.223,localhost,127.0.0.1,api-staging.aquacare.tech

# Base de données staging (SÉPARÉE de prod — ne jamais utiliser aquacare_db ici)
POSTGRES_DB=aquacare_staging_db
POSTGRES_USER=aquacare_staging_user
POSTGRES_PASSWORD=<NOUVEAU_MOT_DE_PASSE_DIFFERENT_DE_PROD>
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT — clé différente de prod obligatoire
JWT_SECRET_KEY=<NOUVELLE_CLE_JWT_DIFFERENTE_DE_PROD>

# Docker Compose
COMPOSE_PROJECT_NAME=aquacare_staging

# Sentry — créer un projet "AquaCare Staging" sur sentry.io et copier le DSN ici
SENTRY_DSN=https://db623afd771724eafae1a2261a83ec4d0e04510971830468608.ingest.de.sentry.io/4510971880800336
SENTRY_RELEASE=staging

# Superuser staging
DJANGO_SUPERUSER_PHONE=+237652260368
DJANGO_SUPERUSER_PASSWORD=<MOT_DE_PASSE_STAGING>
DJANGO_SUPERUSER_FIRST_NAME=Christian
DJANGO_SUPERUSER_LAST_NAME=Djoko

# Email (staging → console ou Resend avec domaine staging)
DEFAULT_FROM_EMAIL=staging@aquacare.tech

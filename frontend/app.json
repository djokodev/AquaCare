{
  "expo": {
    "name": "MAVECAM AquaCare",
    "slug": "mavecam-aquacare",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2563eb"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "cm.mavecam.aquacare",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "cm.mavecam.aquacare",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AquaCare a besoin de votre position pour enregistrer la localisation de votre ferme."
        }
      ],
      [
        "react-native-maps",
        {
          "enableGoogleMapsOnIOS": false
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "aquacare",
          "project": "frontend-aquacare"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1e807ed9-807f-42e1-941a-dbe52efd734e"
      }
    },
    "owner": "djokodev"
  }
}
